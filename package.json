{
  "name": "nanoclaw-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NanoClaw-compatible self-hosted AI agent core with OpenAI Codex runtime support.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:runtime": "rm -rf dist && tsc -p tsconfig.runtime.json && tsc -p container/agent-runner/tsconfig.runtime.json",
    "dev": "tsx src/index.ts",
    "serve": "tsx src/index.ts serve",
    "setup": "tsx setup/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:container": "NANOCLAW_RUN_CONTAINER_E2E=1 vitest run tests/container-engine.e2e.test.ts",
    "build:image": "bash ./container/build.sh",
    "start:host": "bash ./scripts/start-host.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cron-parser": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.9",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.1.1"
  }
}
