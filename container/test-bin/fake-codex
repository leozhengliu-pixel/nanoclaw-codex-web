#!/usr/bin/env sh
set -eu

prompt=""
output_file=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    exec|--skip-git-repo-check|--json)
      shift
      ;;
    --sandbox|--color|--model|-a)
      shift 2
      ;;
    -C)
      shift 2
      ;;
    -o|--output-last-message)
      output_file="$2"
      shift 2
      ;;
    *)
      prompt="$1"
      shift
      ;;
  esac
done

if [ -n "$output_file" ]; then
  printf 'fake-codex:%s\n' "$prompt" > "$output_file"
fi

printf '{"type":"thread.started","thread_id":"fake-thread"}\n'
printf '{"type":"turn.started"}\n'
printf '{"type":"item.completed","item":{"id":"item_0","type":"agent_message","text":"fake-codex:%s"}}\n' "$prompt"
printf '{"type":"turn.completed","usage":{"input_tokens":1,"output_tokens":1,"total_tokens":2}}\n'
