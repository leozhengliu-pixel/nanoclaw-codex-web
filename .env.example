NANOCLAW_DATA_ROOT=./data
NANOCLAW_GROUPS_ROOT=./groups
NANOCLAW_SQLITE_PATH=./data/db.sqlite
NANOCLAW_SESSIONS_ROOT=./data/sessions
NANOCLAW_IPC_ROOT=./data/ipc
NANOCLAW_LOGS_ROOT=./logs
NANOCLAW_MAX_CONCURRENCY=2
NANOCLAW_SCHEDULER_POLL_INTERVAL_MS=1000
NANOCLAW_CODEX_BINARY_PATH=codex
NANOCLAW_RUNTIME_TIMEOUT_MS=300000
NANOCLAW_GROUP_WORKSPACE_POLICY=group-scoped
NANOCLAW_SANDBOX_PROVIDER=container
NANOCLAW_CONTAINER_EXECUTOR=engine
NANOCLAW_CONTAINER_ENGINE_BINARY=docker
NANOCLAW_CONTAINER_IMAGE=nanoclaw-codex-agent:latest
NANOCLAW_CONTAINER_RUNNER_ENTRYPOINT=./container/agent-runner/src/index.ts
NANOCLAW_CONTAINER_RUNNER_PATH_IN_IMAGE=/app/dist/container/agent-runner/src/index.js
NANOCLAW_AGENT_RUNNER_MODE=codex
NANOCLAW_ASSISTANT_NAME=Andy
NANOCLAW_DEFAULT_TRIGGER=@Andy
NANOCLAW_MOUNT_ALLOWLIST_PATH=./config-examples/mount-allowlist.json
NANOCLAW_DEFAULT_TIMEZONE=UTC
NANOCLAW_CONTAINER_SKILLS_PATH=./container/skills
NANOCLAW_WEB_ENABLED=true
NANOCLAW_WEB_BIND=127.0.0.1
NANOCLAW_WEB_PORT=4318
NANOCLAW_WEB_PUBLIC_BASE_URL=https://chat.example.com
NANOCLAW_WEB_ALLOWED_ORIGINS=https://chat.example.com
NANOCLAW_WEB_TRUSTED_PROXIES=127.0.0.1
NANOCLAW_WEB_AUTH_MODE=trusted-proxy
NANOCLAW_WEB_AUTH_TRUSTED_PROXY_USER_HEADER=x-forwarded-user
NANOCLAW_WEB_AUTH_TRUSTED_PROXY_REQUIRED_HEADERS=x-forwarded-proto,x-forwarded-host
NANOCLAW_WEB_AUTH_TRUSTED_PROXY_ALLOW_USERS=
NANOCLAW_WEB_MESSAGE_MAX_CHARS=16000
NANOCLAW_WEB_CHAT_HISTORY_MAX_CHARS=4000
NANOCLAW_WEB_RATE_LIMIT_CONNECT_PER_MINUTE=30
NANOCLAW_WEB_RATE_LIMIT_SEND_PER_MINUTE=60
NANOCLAW_WEB_RATE_LIMIT_HISTORY_PER_MINUTE=120
