NANOCLAW_DATA_ROOT=./data
NANOCLAW_GROUPS_ROOT=./groups
NANOCLAW_SQLITE_PATH=./data/db.sqlite
NANOCLAW_SESSIONS_ROOT=./data/sessions
NANOCLAW_IPC_ROOT=./data/ipc
NANOCLAW_LOGS_ROOT=./logs
NANOCLAW_MAX_CONCURRENCY=2
NANOCLAW_SCHEDULER_POLL_INTERVAL_MS=1000
NANOCLAW_CODEX_BINARY_PATH=codex
NANOCLAW_RUNTIME_TIMEOUT_MS=300000
NANOCLAW_GROUP_WORKSPACE_POLICY=group-scoped
NANOCLAW_SANDBOX_PROVIDER=container
NANOCLAW_CONTAINER_EXECUTOR=engine
NANOCLAW_CONTAINER_ENGINE_BINARY=docker
NANOCLAW_CONTAINER_IMAGE=nanoclaw-multiruntime-agent:latest
NANOCLAW_CONTAINER_RUNNER_ENTRYPOINT=./container/agent-runner/src/index.ts
NANOCLAW_CONTAINER_RUNNER_PATH_IN_IMAGE=/app/container/agent-runner/src/index.ts
NANOCLAW_AGENT_RUNNER_MODE=codex
NANOCLAW_ASSISTANT_NAME=Andy
NANOCLAW_DEFAULT_TRIGGER=@Andy
NANOCLAW_MOUNT_ALLOWLIST_PATH=./config-examples/mount-allowlist.json
NANOCLAW_DEFAULT_TIMEZONE=UTC
NANOCLAW_CONTAINER_SKILLS_PATH=./container/skills
